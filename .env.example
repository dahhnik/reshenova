# Supabase (server-side)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase (frontend / Vite — same URL, anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Telegram
TELEGRAM_BOT_TOKEN=your-bot-token

# Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Google Sheets (base64-encoded service account JSON)
# Generate with: base64 -i service-account.json | tr -d '\n'
GOOGLE_SERVICE_ACCOUNT_JSON=base64-encoded-json

# App (set automatically by Vercel in production)
VERCEL_URL=https://your-project.vercel.app
